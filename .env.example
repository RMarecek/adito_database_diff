NODE_ENV=development
PORT=3000
AUTH_REQUIRED=true
JWT_SECRET=change-me
JWT_AUDIENCE=schema-compare
JWT_ISSUER=schema-compare-api
DB_TYPE=sqlite
DB_LOGGING=false
DB_SYNCHRONIZE=false
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=schema_compare
DB_SID=ORCLCDB
DB_SERVICE_NAME=
SQLITE_PATH=./local.db
CRM_TIMEOUT_MS=30000
CRM_METADATA_PAGE_SIZE=200
CRM_METADATA_DETAIL_LEVEL=fast
CRM_METADATA_INCLUDE_COLUMN_DEFAULTS=false
CRM_METADATA_INCLUDE_COLUMN_COMMENTS=false
CRM_METADATA_INCLUDE_INDEX_EXPRESSIONS=false
CRM_METADATA_USE_CACHE=true
CRM_METADATA_CACHE_TTL_SECONDS=120
CRM_METADATA_MAX_OBJECTS_PER_PAGE=80
